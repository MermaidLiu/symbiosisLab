.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #660874;
}

.meta {
  margin-top: 10rpx;
  font-size: 26rpx;
}

.desc {
  margin-top: 20rpx;
  color: #4b5563;
  line-height: 1.5;
}

.section {
  font-weight: 600;
  margin-bottom: 16rpx;
}

.field {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label {
  width: 100rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.picker,
.input {
  flex: 1;
  background: #f9f5fb;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.hint {
  margin-top: 16rpx;
  font-size: 22rpx;
}
