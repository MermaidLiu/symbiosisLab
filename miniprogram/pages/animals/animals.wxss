.search input {
  background: #f9f5fb;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.id {
  font-family: monospace;
  font-weight: 700;
  color: #660874;
}

.edit-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.editor {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
}

.editor-title {
  font-weight: 700;
  margin-bottom: 20rpx;
}

.input {
  background: #f9f5fb;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.color-label {
  margin: 20rpx 0 12rpx;
  font-size: 24rpx;
}

.colors {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.swatch {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.swatch.on {
  border-color: #660874;
  transform: scale(1.1);
}

.editor-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 28rpx;
}
