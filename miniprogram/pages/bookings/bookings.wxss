.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-weight: 600;
}

.badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.badge-approved {
  background: #e8f5e9;
  color: #2e7d32;
}

.badge-pending {
  background: #fff8e1;
  color: #f57f17;
}

.badge-cancelled,
.badge-rejected {
  background: #f5f5f5;
  color: #616161;
}

.badge-completed {
  background: #e3f2fd;
  color: #1565c0;
}

.ops {
  margin-top: 16rpx;
}
