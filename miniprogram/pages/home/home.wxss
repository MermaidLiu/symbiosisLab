.page {
  padding-bottom: 40rpx;
}

.hero {
  background: linear-gradient(135deg, #660874, #82318e);
  color: #fff;
}

.hello {
  font-size: 36rpx;
  font-weight: 700;
}

.roles {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.85) !important;
  font-size: 24rpx;
}

.stats {
  display: flex;
  flex-wrap: wrap;
  padding: 0 12rpx;
}

.stat {
  width: calc(50% - 24rpx);
  margin: 12rpx;
  text-align: center;
}

.num {
  font-size: 44rpx;
  font-weight: 700;
  color: #660874;
}

.section-title {
  font-weight: 600;
  margin-bottom: 16rpx;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
