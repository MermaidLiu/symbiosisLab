.search input {
  background: #f9f5fb;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.item .row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-weight: 600;
  font-size: 30rpx;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.status-available {
  background: #e8f5e9;
  color: #2e7d32;
}

.status-maintenance {
  background: #fff3e0;
  color: #e65100;
}

.status-retired {
  background: #f5f5f5;
  color: #616161;
}
